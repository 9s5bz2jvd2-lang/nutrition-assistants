{
  "_schema": "evidence-ledger-template-v1.0",
  "_description": "Machine-readable four-track evidence ledger schema. One entry per ingredient per formula. All tracks must be executed even if no evidence is found.",

  "_allowed_values": {
    "evidence_status": ["supported", "weak", "absent", "conflicting", "animal_only", "traditional_only", "mechanistic_only"],
    "study_type": ["meta_analysis", "systematic_review", "large_rct", "small_rct", "controlled_trial", "case_report", "none_found"],
    "tcm_t1_status": ["traditional_record_only"],
    "tcm_t2_status": ["pharmacopeial_standard"],
    "tcm_t3_status": ["supported", "weak", "absent", "conflicting", "none_found"],
    "mechanism_is_not_efficacy_proof": [true]
  },

  "_required_ingredient_fields": [
    "ingredient_name",
    "dose_in_formula",
    "track_1_human_clinical",
    "track_2_animal",
    "track_3_tcm_material",
    "track_4_mechanistic_safety",
    "overall_evidence_status"
  ],

